{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "build:dev": "vite build --mode development",
        "build:prod": "vite build --mode production",
        "dev": "vite",
        "deploy:dev": "php artisan config:clear && php artisan route:clear && php artisan view:clear && npm run build:dev",
        "deploy:prod": "php artisan config:cache && php artisan route:cache && php artisan view:cache && npm run build:prod"
    },
    "devDependencies": {
        "@tailwindcss/forms": "^0.5.2",
        "@tailwindcss/vite": "^4.0.0",
        "alpinejs": "^3.4.2",
        "autoprefixer": "^10.4.2",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^3.1",
        "postcss": "^8.4.31",
        "tailwindcss": "^3.1.0",
        "vite": "^8.0.0"
    }
}
